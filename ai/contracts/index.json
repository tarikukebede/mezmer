        "accessControl",
        "accessibility",
        "controlledValue",
        "keyboardPropagationControl"
      ]
    },
    {
      "name": "BaseTable",
      "contractPath": "ai/contracts/components/base-table.contract.json",
      "sourcePath": "src/components/BaseTable",
      "capabilities": [
        "accessControl",
        "selection",
        "pagination",
        "sorting",
        "placeholder",
        "rowInactive"
      ]
    },
    {
      "name": "Icon",
      "contractPath": "ai/contracts/components/icon.contract.json",
